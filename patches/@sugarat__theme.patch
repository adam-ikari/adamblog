   recommend.value?.style ?? 'sidebar'
 )
@@ -109,6 +124,23 @@ const recommendList = computed(() => {
   }
   normalList.sort(compareFn)
 
+  // TF-IDF 向量相关：若构建时生成的 related-posts.json 有当前页的相似文章数据，
+  // 按相似度排序，把语义最相关的排到前面（剩余的按原排序补齐）
+  if (tfidfReady.value) {
+    const currentPath = decodeURIComponent(route.path).replace(/\.html$/, '')
+    const related = tfidfMap.value[currentPath] || []
+    if (related.length) {
+      const order = new Map(related.map((r, i) => [r.link, i]))
+      normalList.sort((a, b) => {
+        const aRoute = a.route.replace(/\.html$/, '')
+        const bRoute = b.route.replace(/\.html$/, '')
+        const aIdx = order.has(aRoute) ? order.get(aRoute) : Infinity
+        const bIdx = order.has(bRoute) ? order.get(bRoute) : Infinity
+        return aIdx - bIdx
+      })
+    }
+  }
+
   return topList.concat(normalList)
 })
 
