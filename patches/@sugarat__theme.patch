@@ -12,6 +12,21 @@ const formatShowDate = useFormatShowDate()
 const recommend = useRecommendConfig()
 const show = useShowRecommend()
 
+// TF-IDF 相关文章数据：构建时生成 related-posts.json，记录每篇文章的 top-N 相似文章
+const tfidfMap = ref<Record<string, { title: string; link: string }[]>>({})
+const tfidfReady = ref(false)
+onMounted(async () => {
+  try {
+    const res = await fetch('/related-posts.json')
+    if (res.ok)
+      tfidfMap.value = await res.json()
+  }
+  catch {}
+  finally {
+    tfidfReady.value = true
+  }
+})
+
 const sidebarStyle = computed(() =>
   recommend.value?.style ?? 'sidebar'
 )
@@ -109,6 +124,21 @@ const recommendList = computed(() => {
   }
   normalList.sort(compareFn)
 
+  // TF-IDF 向量相关：若构建时生成的 related-posts.json 有当前页的相似文章数据，
+  // 候选池限定为该 top-N 列表（按相似度排序），不再混入同前缀的全站文章。
+  // 没有数据（如非文章页）则回退到上面的同前缀候选池。
+  if (tfidfReady.value) {
+    const currentPath = decodeURIComponent(route.path).replace(/\.html$/, '')
+    const related = tfidfMap.value[currentPath] || []
+    if (related.length) {
+      const order = new Map(related.map((r, i) => [r.link, i]))
+      const tfidfList = normalList
+        .filter((v) => order.has(v.route.replace(/\.html$/, '')))
+        .sort((a, b) => order.get(a.route.replace(/\.html$/, '')) - order.get(b.route.replace(/\.html$/, '')))
+      return topList.concat(tfidfList)
+    }
+  }
+
   return topList.concat(normalList)
 })
 
